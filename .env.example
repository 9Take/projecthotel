# 🏨 Lumina Hotel IoT Dashboard - Environment Configuration
# Copy this file to .env and edit values to match your system

# ==========================================
# 1. DATABASE CONFIGURATION
# ==========================================
DB_HOST=mysql                    # MySQL server hostname
DB_USER=root                     # MySQL username
DB_PASSWORD=hotel123             # MySQL password (change for security!)
DB_NAME=hotel_db                 # Database name

# ==========================================
# 2. MQTT BROKER CONFIGURATION
# ==========================================
MQTT_HOST=mqtt                   # MQTT broker hostname
MQTT_PORT=1883                   # MQTT port (default 1883)
MQTT_USER=mosquitto              # MQTT username
MQTT_PASSWORD=mosquitto          # MQTT password (change for security!)

# ==========================================
# 3. AUTHENTICATION CREDENTIALS
# ==========================================
# Admin Account
ADMIN_USER=admin                 # Admin username
ADMIN_PASS=admin123              # Admin password (change for security!)

# Guest Account
GUEST_USER=guest                 # Guest username
GUEST_PASS=guest123              # Guest password (change for security!)

# ==========================================
# 4. SECURITY KEYS
# ==========================================
# *** IMPORTANT: Must match m5.ino line 19: const String SECRET_KEY = "LUMINA2026" ***
SECRET_KEY=LUMINA2026            # Payload verification key (change this!)
SESSION_SECRET=your-session-key  # Session secret (use random key, change this!)

# ==========================================
# 5. SERVER CONFIGURATION (Optional)
# ==========================================
NODE_ENV=production              # development / production
PORT=3000                        # Server port
LOG_LEVEL=info                   # Logging level (debug/info/warn/error)

# ==========================================
# IMPORTANT NOTES:
# ==========================================
# 1. !!IMPORTANT!! Change ADMIN_PASS, GUEST_PASS, SECRET_KEY, SESSION_SECRET
#    to secure values before using in Production
#
# 2. Make sure SECRET_KEY matches m5.ino:19
#    const String SECRET_KEY = "LUMINA2026"
#    If not matching, device will reject all messages
#
# 3. Using Docker: These variables are already mounted via .env
#    After editing .env, run: docker compose restart hotel_dashboard
#
# 4. Manual installation: Load .env using dotenv package
#    require('dotenv').config();
