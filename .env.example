# 🏨 Lumina Hotel IoT Dashboard - Environment Configuration
# Copy this file to .env และแก้ไขค่าให้ตรงกับระบบของคุณ

# ==========================================
# 1. DATABASE CONFIGURATION
# ==========================================
DB_HOST=mysql                    # MQTT broker hostname
DB_USER=root                     # MySQL username
DB_PASSWORD=hotel123             # MySQL password (เปลี่ยนให้ปลอดภัย!)
DB_NAME=hotel_db                 # Database name

# ==========================================
# 2. MQTT BROKER CONFIGURATION
# ==========================================
MQTT_HOST=mqtt                   # MQTT broker hostname
MQTT_PORT=1883                   # MQTT port (default 1883)
MQTT_USER=mosquitto              # MQTT username
MQTT_PASSWORD=mosquitto          # MQTT password (เปลี่ยนให้ปลอดภัย!)

# ==========================================
# 3. AUTHENTICATION CREDENTIALS
# ==========================================
# Admin Account
ADMIN_USER=admin                 # Admin username
ADMIN_PASS=admin123              # Admin password (เปลี่ยนให้ปลอดภัย!)

# Guest Account
GUEST_USER=guest                 # Guest username
GUEST_PASS=guest123              # Guest password (เปลี่ยนให้ปลอดภัย!)

# ==========================================
# 4. SECURITY KEYS
# ==========================================
# *** ต้องตรงกับ m5.ino ที่ line 19: const String SECRET_KEY = "LUMINA2026" ***
SECRET_KEY=LUMINA2026            # Payload verification key (เปลี่ยน!)
SESSION_SECRET=your-session-key  # Session secret (random key, เปลี่ยน!)

# ==========================================
# 5. SERVER CONFIGURATION (Optional)
# ==========================================
NODE_ENV=production              # development / production
PORT=3000                        # Server port
LOG_LEVEL=info                   # Logging level (debug/info/warn/error)

# ==========================================
# NOTES:
# ==========================================
# 1. !!IMPORTANT!! ให้เปลี่ยน ADMIN_PASS, GUEST_PASS, SECRET_KEY, SESSION_SECRET
#    ให้ปลอดภัยมากขึ้น ก่อนใช้บน Production
#
# 2. ตรวจสอบให้ SECRET_KEY ตรงกับ m5.ino:19
#    const String SECRET_KEY = "LUMINA2026"
#    ถ้าไม่ตรง Device จะ reject message ทั้งหมด
#
# 3. ถ้าใช้ Docker: ตัวแปรเหล่านี้จะถูก mount ให้
#    แก้ .env แล้วรัน: docker compose restart hotel_dashboard
#
# 4. ถ้าติดตั้ง Manual: load .env โดยใช้ dotenv package
#    require('dotenv').config();
